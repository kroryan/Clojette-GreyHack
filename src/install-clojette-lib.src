f = hostComputer.File("/lib/clojette/macros.clj")
if f == null then
    hostComputer.touch("/lib/clojette", "macros.clj")
    f = hostComputer.File("/lib/clojette/macros.clj")
end if
setResult = f.set_content(macrosContent)
if typeof(setResult) == "string" then print("install-clojette-lib: failed writing macros.clj: " + setResult)

f = hostComputer.File("/lib/clojette/stdlib.clj")
if f == null then
    hostComputer.touch("/lib/clojette", "stdlib.clj")
    f = hostComputer.File("/lib/clojette/stdlib.clj")
end if
setResult = f.set_content(stdlibContent)
if typeof(setResult) == "string" then print("install-clojette-lib: failed writing stdlib.clj: " + setResult)

print("Clojette standard library installed at /lib/clojette/ on this computer.")